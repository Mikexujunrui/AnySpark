# ============================================
# LLM 配置
# ============================================

# [必填] DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-api-key-here

# [可选] API 基础地址（默认 DeepSeek 官方）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# [可选] 模型名称
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash

# [可选] LLM 调度模式: split（双模型分工）/ pro（全用 Pro）/ flash（全用 Flash）
LLM_MODE=split

# ============================================
# Neo4j 图数据库配置
# ============================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# ⚠️ 安全提示：生产环境请务必修改为强密码！
# 建议使用至少 16 位包含大小写字母、数字和特殊字符的密码
NEO4J_PASSWORD=novel_agent_2024!

# ============================================
# 服务配置
# ============================================

# [可选] 后端端口（默认 8191）
SERVER_PORT=8191

# ============================================
# 联网搜索（可选功能）
# ============================================

# 联网搜索总开关（默认 true）
# WEBSEARCH_ENABLED=true

# 搜索后端: exa / parallel（留空自动 A/B 分流）
# WEBSEARCH_PROVIDER=

# Exa 搜索 API Key（从 https://exa.ai 获取）
# EXA_API_KEY=

# Parallel 搜索 API Key
# PARALLEL_API_KEY=
